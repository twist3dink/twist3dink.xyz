    <script>
        // Track lesson progress
        function trackProgress(lessonNumber) {
            const progress = JSON.parse(localStorage.getItem('flipperProgress') || '{}');
            progress[`lesson${lessonNumber}`] = 'completed';
            localStorage.setItem('flipperProgress', JSON.stringify(progress));
        }

        // Load progress on page load
        document.addEventListener('DOMContentLoaded', function() {
            const progress = JSON.parse(localStorage.getItem('flipperProgress') || '{}');
            
            // Update lesson cards based on progress
            document.querySelectorAll('.lesson-card').forEach((card, index) => {
                const lessonNum = index + 1;
                if (progress[`lesson${lessonNum}`] === 'completed') {
                    card.querySelector('.lesson-status').textContent = '✅ Completed';
                    card.querySelector('.lesson-status').classList.remove('available', 'locked');
                    card.querySelector('.lesson-status').classList.add('completed');
                }
            });
        });
    </script>
